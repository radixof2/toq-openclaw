{
  "name": "toq-channel",
  "version": "0.1.0",
  "description": "OpenClaw channel plugin for toq protocol",
  "type": "module",
  "main": "src/index.ts",
  "openclaw": {
    "extensions": ["./src/index.ts"],
    "channel": {
      "id": "toq",
      "label": "toq protocol",
      "selectionLabel": "toq protocol (agent-to-agent)",
      "blurb": "Secure agent-to-agent communication via toq protocol",
      "aliases": ["toq-protocol"],
      "order": 80
    }
  },
  "scripts": {
    "test": "vitest run"
  },
  "files": [
    "src/index.ts",
    "openclaw.plugin.json"
  ],
  "dependencies": {
    "@toqprotocol/toq": ">=0.1.0-dev.1"
  },
  "devDependencies": {
    "vitest": "^3.0"
  },
  "engines": { "node": ">=18" },
  "license": "Apache-2.0"
}
